<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HYDRA // NEURAL CONTROL INTERFACE</title>

    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;800&family=Rajdhani:wght@400;600&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

    <style>
        /* ================= GLOBAL ================= */
        *{margin:0;padding:0;box-sizing:border-box}

        body{
            font-family:'Orbitron',sans-serif;
            background:#000000;
            color:white;
            overflow-x:hidden;
        }

        /* ================= LOADER ================= */
        #loader{
            position:fixed;
            inset:0;
            background:#000000;
            display:flex;
            flex-direction:column;
            justify-content:center;
            align-items:center;
            z-index:9999;
        }

        .loader-bar{
            width:280px;
            height:4px;
            background:#111;
            border-radius:5px;
            overflow:hidden;
            margin-top:20px;
        }

        .loader-fill{
            height:100%;
            width:0%;
            background:linear-gradient(90deg,#00f0ff,#ff00f0);
        }

        /* ================= BACKGROUND GRID ================= */
        body::before{
            content:"";
            position:fixed;
            inset:0;
            background-image:
                linear-gradient(rgba(0,255,255,.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0,255,255,.03) 1px, transparent 1px);
            background-size:80px 80px;
            animation:gridMove 60s linear infinite;
            z-index:-2;
        }

        @keyframes gridMove{from{transform:translateY(0)}to{transform:translateY(80px)}}

        #particles{position:fixed;inset:0;z-index:-1}

        /* ================= NAV ================= */
        nav{
            position:fixed;
            width:100%;
            top:0;
            display:flex;
            justify-content:center;
            gap:40px;
            padding:20px;
            background:rgba(0,0,0,.85);
            backdrop-filter:blur(20px);
            border-bottom:1px solid rgba(0,255,255,.15);
            z-index:10;
        }

        nav a{color:#8efcff; text-decoration:none; letter-spacing:2px; transition:.3s;}
        nav a:hover{color:#00f0ff}

        /* ================= HERO ================= */
        .hero{
            height:100vh;
            display:flex;
            flex-direction:column;
            align-items:center;
            justify-content:center;
            text-align:center;
            perspective:1000px;
        }

        .logo-frame{
            padding:14px;
            border-radius:20px;
            background:linear-gradient(120deg,#00f0ff,#ff00f0,#00f0ff);
            animation:grad 6s infinite linear;
            box-shadow:0 0 70px rgba(0,255,255,.5);
        }

        @keyframes grad{0%{filter:hue-rotate(0)}100%{filter:hue-rotate(360deg)}}
        .logo{width:170px; border-radius:14px; background:black}

        .glitch{
            font-size:80px;
            margin-top:25px;
            color:#00f0ff;
            text-shadow: 0 0 10px #00f0ff, 0 0 25px #00f0ff;
        }

        .hero p{max-width:700px; opacity:.85; margin:20px 0 40px; font-family:'Rajdhani';}

        .discord-btn{
            padding:16px 50px;
            border-radius:12px;
            background:linear-gradient(90deg,#00f0ff,#ff00f0);
            color:white;
            text-decoration:none;
            letter-spacing:2px;
            font-weight:700;
            border:none;
            cursor:pointer;
            display:inline-block;
            box-shadow:0 0 25px rgba(0,255,255,.4);
        }

        /* ================= SECTIONS ================= */
        section{padding:100px 12%;}
        .section-title{font-size:42px; margin-bottom:40px; color:#00f0ff; text-align:center;}

        .features-grid{
            display:grid;
            grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
            gap:30px;
        }

        .feature{
            padding:30px;
            border-radius:18px;
            background:rgba(0,255,255,.05);
            border:1px solid rgba(0,255,255,.25);
            backdrop-filter:blur(25px);
            text-align:center;
        }

        .terminal{
            background:#050505;
            padding:35px;
            border-radius:15px;
            border:1px solid #00f0ff;
            font-family:monospace;
            color:#00ff9f;
            min-height:200px;
        }

        .login{max-width:420px; margin:auto; display:flex; flex-direction:column; gap:18px;}
        .login input{
            padding:14px; border-radius:10px; border:1px solid rgba(0,255,255,.25);
            background:#050505; color:white; font-family:'Orbitron';
        }

        footer{text-align:center; padding:100px; opacity:.5}
    </style>
</head>
<body>

    <div id="loader">
        <h2>HYDRA INITIALIZING...</h2>
        <div class="loader-bar"><div class="loader-fill"></div></div>
    </div>

    <canvas id="particles"></canvas>

    <nav>
        <a href="#">HOME</a>
        <a href="#features">SYSTEM</a>
        <a href="#terminal">CONSOLE</a>
        <a href="#download">DOWNLOAD</a>
    </nav>

    <section class="hero">
        <div class="logo-frame">
            <img class="logo" src="https://via.placeholder.com/170x170?text=HYDRA">
        </div>
        <h1 class="glitch">HYDRA</h1>
        <p>Neural hardware identity control system with temporary session masking.</p>
        <div id="users" style="color: #00f0ff;">0 USERS ONLINE</div>
    </section>

    <section id="features">
        <h2 class="section-title">SYSTEM MODULES</h2>
        <div class="features-grid">
            <div class="feature">Identity Rotation Engine</div>
            <div class="feature">Session Reset Protocol</div>
            <div class="feature">Protected Runtime Layer</div>
        </div>
    </section>

    <section id="terminal">
        <h2 class="section-title">LIVE CONSOLE</h2>
        <div class="terminal" id="terminalText"></div>
    </section>

    <section id="download">
        <h2 class="section-title">LOADER ACCESS</h2>
        <div style="text-align:center; background: rgba(0,255,255,0.05); padding: 50px; border-radius: 20px; border: 1px dashed #00f0ff;">
            <h3>HYDRA_LOADER_V2.EXE</h3>
            <p style="margin: 20px 0;">Status: <span style="color: #00ff9f;">Encrypted</span></p>
            <a class="discord-btn" href="https://gofile.io/d/VEmRby" target="_blank">DOWNLOAD NOW</a>
        </div>
    </section>

    <section>
        <h2 class="section-title">CONTROL LOGIN</h2>
        <div class="login" id="loginBox">
            <input type="text" id="userField" placeholder="USERNAME">
            <input type="password" id="keyField" placeholder="LICENSE KEY (Hint: HYDRA-2026)">
            <button class="discord-btn" id="authBtn">AUTHENTICATE</button>
        </div>
    </section>

    <footer>HYDRA NEURAL INTERFACE // 2026</footer>

    <script>
        /* 1. LOADER LOGIC */
        let load = 0;
        const fill = document.querySelector('.loader-fill');
        const loader = document.getElementById('loader');
        const loadInterval = setInterval(() => {
            load += 2;
            fill.style.width = load + '%';
            if(load >= 100){
                clearInterval(loadInterval);
                gsap.to(loader, {opacity:0, duration:1, onComplete:()=>loader.remove()});
            }
        }, 30);

        /* 2. BACKGROUND PARTICLES */
        const canvas = document.getElementById('particles');
        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth; canvas.height = window.innerHeight;
        let particles = [];
        for(let i=0; i<100; i++) particles.push({x:Math.random()*canvas.width, y:Math.random()*canvas.height, r:Math.random()*2});
        function draw(){
            ctx.clearRect(0,0,canvas.width,canvas.height);
            ctx.fillStyle='#00f0ff';
            particles.forEach(p=>{ ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2); ctx.fill(); });
            requestAnimationFrame(draw);
        }
        draw();

        /* 3. TERMINAL TYPEWRITER EFFECT */
        const lines = ['Initializing identity engine...', 'Loading session mask...', 'Accessing neural cores...', 'System ready.'];
        let t = 0;
        function type(){
            if(t < lines.length){
                document.getElementById('terminalText').innerHTML += "> " + lines[t] + '<br>';
                t++; setTimeout(type, 1000);
            }
        }
        type();

        /* 4. THE KEY SYSTEM */
        document.getElementById('authBtn').addEventListener('click', function() {
            const user = document.getElementById('userField').value;
            const key = document.getElementById('keyField').value;

            // SET VALID KEYS HERE
            const validKeys = ["HYDRA-2026", "GUEST-88", "ADMIN-TEST"];

            if (validKeys.includes(key)) {
                alert("ACCESS GRANTED. Welcome back, " + (user || "Agent"));
                window.location.href = "#download"; // Scrolls to download section
            } else {
                alert("ACCESS DENIED: Invalid License Key.");
                // SHAKE ANIMATION ON ERROR
                gsap.to("#loginBox", { x: 10, duration: 0.1, repeat: 5, yoyo: true });
            }
        });

        /* 5. FAKE USER COUNTER */
        let userCount = 1240;
        setInterval(() => {
            userCount += Math.floor(Math.random()*2);
            document.getElementById('users').textContent = userCount + ' USERS ONLINE';
        }, 2000);
    </script>
</body>
</html>
